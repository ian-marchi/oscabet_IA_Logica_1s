# ── Ollama Cloud ──────────────────────────────────────────────────────────────
# Crie sua API key em: https://ollama.com/settings/keys
OLLAMA_API_KEY=2ddeddb7a96d450a8e20959a4638c0f9.cE5F8TDdQUVsgsEyKiPPcFXA
OLLAMA_HOST=https://ollama.com

# Modelos recomendados para tool calling:
#   llama3.3:70b   → melhor raciocínio e tool use (recomendado)
#   qwen2.5:72b    → excelente em português e tool use
#   gpt-oss:120b   → modelo GPT-based da Ollama
OLLAMA_MODEL=gpt-oss:120b

# ── Configurações do Agente ───────────────────────────────────────────────────
DEFAULT_WINDOW=10
MIN_GAMES_REQUIRED=3
CONFIDENCE_THRESHOLD=0.5

# ── Thresholds Over/Under ─────────────────────────────────────────────────────
YELL_LINE=6.5
CORN_LINE=10.5

# ── Flask API (próxima etapa) ─────────────────────────────────────────────────
FLASK_ENV=development
FLASK_PORT=5000
