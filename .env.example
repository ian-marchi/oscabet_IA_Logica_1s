# ── Ollama Cloud ──────────────────────────────────────────────────────────────
# Crie sua API key em: https://ollama.com/settings/keys
OLLAMA_API_KEY=sua_chave_aqui
OLLAMA_HOST=https://ollama.com

# Modelos recomendados para tool calling:
#   llama3.3:70b   → melhor raciocínio e tool use (recomendado)
#   qwen2.5:72b    → excelente em português e tool use
#   gpt-oss:120b   → modelo GPT-based da Ollama
OLLAMA_MODEL=llama3.3:70b

# ── Configurações do Agente ───────────────────────────────────────────────────
DEFAULT_WINDOW=10
MIN_GAMES_REQUIRED=3
CONFIDENCE_THRESHOLD=0.5

# ── Thresholds Over/Under (linhas REAIS dos alvos, definidas no notebook 02) ──
YELL_LINE=4.5
CORN_LINE=9.5

# ── Decisão de empate (predictor.py) ──────────────────────────────────────────
# O empate raramente é o resultado isoladamente mais provável, então o argmax
# quase nunca o escolhe. Estas margens controlam a camada de decisão:
#   DRAW_MARGIN      → se o Empate está a <= esta distância do favorito, o "pick"
#                      vira Empate (0.05 = 5pp). Use 0.0 para acurácia bruta máxima.
#   EQUILIBRIO_MARGIN→ se top1-top2 <= isto, marca o jogo como "equilibrado" (badge).
DRAW_MARGIN=0.05
EQUILIBRIO_MARGIN=0.08

# ── Flask API (próxima etapa) ─────────────────────────────────────────────────
FLASK_ENV=development
FLASK_PORT=5000
